<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>fb2a8771-0f82-4d9e-a27c-ab3e8ccf5acb</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>rag_chatbot_project.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>rag-chatbot-project</Name>
    <RootNamespace>rag-chatbot-project</RootNamespace>
    <InterpreterId>MSBuild|env3|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="app.py" />
    <Compile Include="rag_chatbot_project.py" />
    <Compile Include="src\database.py" />
    <Compile Include="src\loader.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="data\" />
    <Folder Include="faiss_index\" />
    <Folder Include="src\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include=".env" />
    <Content Include="README.md" />
    <Content Include="requirements.txt" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env2\">
      <Id>env2</Id>
      <Version>0.0</Version>
      <Description>env2 (Python 3.14 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
    <Interpreter Include="env3\">
      <Id>env3</Id>
      <Version>3.11</Version>
      <Description>env3 (Python 3.11 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
    <Interpreter Include="env\">
      <Id>env</Id>
      <Version>3.9</Version>
      <Description>env (Python 3.9 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
  <!--<Target Name="CoreCompile" />-->
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>